# Copy to .env and adjust. Safe defaults: execution and live trading off; read API not public until you opt in.

APP_ENV=development
APP_NAME=Market Mate Scanner API
APP_VERSION=1.0.0
DATABASE_URL=sqlite:///./market_mate.db
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth: in production set APP_ENV=production and ADMIN_API_TOKEN. For local dev you may set PUBLIC_READ_ACCESS_ENABLED=true
# without tokens; for serious environments keep public read off and set READ_API_TOKEN.
# Mirror READ_API_TOKEN into apps/web SCANNER_READ_API_TOKEN.
# Mirror ADMIN_API_TOKEN into apps/web SCANNER_ADMIN_API_TOKEN.
PUBLIC_READ_ACCESS_ENABLED=true
READ_API_TOKEN=
ADMIN_API_TOKEN=

LOG_LEVEL=INFO
LOG_JSON=true
METRICS_ENABLED=true

HEALTH_MAX_STALE_MINUTES=30
SIGNAL_MAX_AGE_MINUTES=120
REQUIRE_READYZ_FOR_EXECUTION=true
TRUST_RECENT_WINDOW_DAYS=14

SCHEDULER_ENABLED=false
SCHEDULER_POLL_SECONDS=15
SCHEDULER_LEASE_SECONDS=120
SCHEDULER_RUN_MISSED_ON_STARTUP=true

# Watchlist: defaults live in config.py; env overrides take precedence.
# SPY and QQQ are required for market-status benchmarking but are excluded from scan rows.
# SEC + options calls run per stock per scan; news calls fire only when price/RS thresholds hit.
# With ~49 stocks + 20 crypto the scan takes roughly 4-5x longer than the original 12+2 list.
# If latency or provider errors increase, trim lists or lower SCAN_CONCURRENCY_LIMIT.
WATCHLIST=AAPL,MSFT,NVDA,AMD,META,AMZN,GOOGL,AVGO,CRM,ORCL,CSCO,INTC,TSLA,NFLX,DIS,JPM,BAC,GS,MS,V,MA,BRK.B,UNH,JNJ,LLY,MRK,ABBV,XOM,CVX,CAT,DE,UPS,WMT,PG,KO,PEP,HD,NKE,MCD,LIN,NEE,T,VZ,AMAT,LRCX,COIN,PLTR,SPY,QQQ
# Crypto pairs must use BASE/USD format matching Alpaca v1beta3 crypto/us endpoint.
# All pairs below are verified against Alpaca's supported USD pairs.
CRYPTO_WATCHLIST=BTC/USD,ETH/USD,SOL/USD,XRP/USD,DOGE/USD,ADA/USD,AVAX/USD,LINK/USD,DOT/USD,LTC/USD,UNI/USD,SHIB/USD,BCH/USD,AAVE/USD,POL/USD,PEPE/USD,FIL/USD,GRT/USD,RENDER/USD,BONK/USD
SCAN_INTERVAL_SECONDS=300
SCAN_CONCURRENCY_LIMIT=8
CACHE_DIR=./var/cache

TRADE_GATE_ENABLED=true
TRADE_GATE_HORIZON=1h
TRADE_GATE_MIN_EVALUATED_COUNT=20
TRADE_GATE_MIN_WIN_RATE=55
TRADE_GATE_MIN_AVG_RETURN=0.15
TRADE_GATE_ALLOWED_SIGNALS=BUY,SELL
TRADE_GATE_MAX_NOTIONAL=1000
TRADE_GATE_MAX_QTY=5

PORTFOLIO_RISK_ENABLED=true
PORTFOLIO_MAX_DAILY_NOTIONAL=2500
PORTFOLIO_MAX_SYMBOL_NOTIONAL=1000
PORTFOLIO_MAX_ASSET_TYPE_NOTIONAL=2000
PORTFOLIO_DAILY_LOSS_LIMIT_PCT=-2
PORTFOLIO_MAX_LOSS_STREAK=3
PORTFOLIO_MAX_DRAWDOWN_PCT=5

CALIBRATION_MIN_SIGNAL_SAMPLES=20
CALIBRATION_MIN_SCORE_BAND_SAMPLES=10
OUTCOME_REPORT_MIN_EVALUATED_PER_HORIZON=20
OUTCOME_BASELINE_MIN_EVALUATED_PER_HORIZON=20
OUTCOME_BASELINE_MIN_MEAN_RETURN_PCT=0
VALIDATION_PRIMARY_HORIZON=1h
VALIDATION_WIN_THRESHOLD_PCT=0
VALIDATION_FALSE_POSITIVE_THRESHOLD_PCT=0

ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_MARKET_DATA_URL=https://data.alpaca.markets
EXECUTION_ENABLED=false
ALLOW_LIVE_TRADING=false
EXECUTION_DEFAULT_TIME_IN_FORCE=day
LIVE_TRADING_MAX_NOTIONAL=100
LIVE_TRADING_MAX_QTY=1

PROVIDER_TIMEOUT_SECONDS=20
PROVIDER_RETRY_ATTEMPTS=2
PROVIDER_RETRY_BACKOFF_SECONDS=0.5
PROVIDER_MAX_BAR_AGE_MINUTES=20
ALPACA_LATEST_DATA_CACHE_SECONDS=5
SEC_COMPANY_TICKERS_CACHE_SECONDS=21600
SEC_FILINGS_CACHE_SECONDS=900
COINGECKO_CACHE_SECONDS=120
FEAR_GREED_CACHE_SECONDS=300
OPTIONS_FLOW_CACHE_SECONDS=600

MARKETDATA_API_TOKEN=
MARKETAUX_API_TOKEN=
FINNHUB_API_KEY=
COINGECKO_API_KEY=
COINBASE_WS_ENABLED=true
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
COINBASE_WS_CHANNEL=ticker
COINBASE_WS_PRODUCTS=BTC-USD,ETH-USD
COINBASE_WS_RECONNECT_BASE_SECONDS=1
COINBASE_WS_RECONNECT_MAX_SECONDS=30
COINBASE_WS_SNAPSHOT_STALE_SECONDS=150
COINBASE_WS_LOG_MESSAGES=true
SEC_USER_AGENT=MarketMateScanner your-email@example.com

TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_SCORE_THRESHOLD=65
NEWS_CHECK_SCORE_THRESHOLD=60
NEWS_CACHE_MINUTES=45

REPLAY_DEFAULT_INTERVAL_MINUTES=60
REPLAY_DEFAULT_WARMUP_BARS=30

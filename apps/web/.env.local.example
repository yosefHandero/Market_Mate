# Must match the port where uvicorn runs (see repo README: default 8005).
NEXT_PUBLIC_SCANNER_API_BASE=http://127.0.0.1:8005

# Server-side only. Set this to services/scanner READ_API_TOKEN when
# PUBLIC_READ_ACCESS_ENABLED=false.
SCANNER_READ_API_TOKEN=

# Server-side only. Set this to services/scanner ADMIN_API_TOKEN for
# journal writes and optional reconciliation checks.
SCANNER_ADMIN_API_TOKEN=

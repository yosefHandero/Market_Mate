# Environment Configuration
# Copy this file to .env and fill in your actual values

# Application
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Finnhub API - Get your key from https://finnhub.io
# Use NEXT_PUBLIC_FINNHUB_API_KEY for client-side access, or FINNHUB_API_KEY for server-side only
NEXT_PUBLIC_FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# MongoDB - Get your connection string from https://www.mongodb.com/cloud/atlas
MONGODB_URI=

# Better Auth - Generate a secure random string for production
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Gemini AI - Get your key from https://aistudio.google.com
GEMINI_API_KEY=

# Optional: Keepalive API key for external keepalive services
# KEEPALIVE_API_KEY=
